QUESTION_BANK_RUNTIME_HOST=127.0.0.1
QUESTION_BANK_RUNTIME_PORT=8000
QUESTION_BANK_ADMIN_HOST=127.0.0.1
QUESTION_BANK_ADMIN_PORT=8001
# Optional container-internal SQLite path. The default is /app/data/fe_siken_questions.sqlite.
# HOST_DATA_DIR on the VPS is mounted to /app/data inside the container.
# QUESTION_DB_PATH=/app/data/fe_siken_questions.sqlite
# Optional container-internal keyword JSON paths. Keep these files in HOST_DATA_DIR
# together with fe_siken_questions.sqlite.
# QUESTION_KEYWORD_TAXONOMY_PATH=/app/data/question_keyword_taxonomy.json
# QUESTION_TOPIC_MAPPINGS_PATH=/app/data/question_topic_mappings.json
# Container-internal asset path. HOST_ASSET_DIR on the VPS is mounted here.
QUESTION_ASSET_ROOT=/app/public/assets/fe-siken
HOST_DATA_DIR=/opt/fe-question-bank/data
HOST_ASSET_DIR=/opt/fe-question-bank/public/assets/fe-siken
ADMIN_API_TOKEN=replace-with-a-long-random-token
LOG_LEVEL=info
