QUESTION_BANK_RUNTIME_PORT=8000
QUESTION_BANK_ADMIN_PORT=8001
# Optional container-internal SQLite path. The default is /app/data/fe_siken_questions.sqlite.
# HOST_DATA_DIR on the VPS is mounted to /app/data inside the container.
# QUESTION_DB_PATH=/app/data/fe_siken_questions.sqlite
HOST_DATA_DIR=/opt/fe-question-bank/data
HOST_ASSET_DIR=/opt/fe-question-bank/public/assets/fe-siken
ADMIN_API_TOKEN=replace-with-a-long-random-token
LOG_LEVEL=info
